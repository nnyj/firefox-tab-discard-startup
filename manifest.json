{
  "manifest_version": 2,
  "name": "Tab Discard on Startup",
  "version": "1.1",
  "description": "Discards pinned tabs on startup to trigger pending/dimmed state in TST",
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-discard-startup@local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["tabs"],
  "background": {
    "scripts": ["background.js"]
  }
}
